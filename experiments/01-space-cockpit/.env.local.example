# --- NASA (APOD / NeoWs) ---
# DEMO_KEY は動くが厳しい（10 req/時・50 req/日）。開発は無料キー推奨（1,000 req/時）:
#   https://api.nasa.gov/
NASA_API_KEY=DEMO_KEY

# --- LLM プロバイダ（既定 = Azure OpenAI / lib/server/model.ts で env 差し替え可）---
# public ユーザーは別プロバイダ（OpenAI / Gemini 等）の import + キーに差し替える。
AZURE_OPENAI_API_KEY=
AZURE_RESOURCE_NAME=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
