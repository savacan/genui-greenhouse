# --- PokéAPI ---
# 鍵不要・CORS * ・レート実質無制限（fair-use）。base だけ差し替え可能にしてある。
POKE_API_BASE=https://pokeapi.co/api/v2

# --- LLM プロバイダ（既定 = Azure OpenAI / lib/finder/model.ts で env 差し替え可）---
# public ユーザーは別プロバイダ（OpenAI / Gemini 等）の import + キーに差し替える。
AZURE_OPENAI_API_KEY=
AZURE_RESOURCE_NAME=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
