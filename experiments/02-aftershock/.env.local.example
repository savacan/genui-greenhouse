# --- データ源（全て鍵不要）---
# USGS earthquakes / Open-Meteo / Wikipedia は API キー不要。
# Wikipedia REST は礼儀として User-Agent を求める（無くても 200 だが設定推奨）:
WIKI_USER_AGENT=aftershock/0.1 (genui-greenhouse experiment)

# OpenSky（任意・degrade 前提）。匿名でも動くが厳しめのレート制限。
# OPENSKY_USER=
# OPENSKY_PASS=

# --- LLM プロバイダ（既定 = Azure OpenAI / lib/monitor/model.ts で env 差し替え可）---
# Phase A（データ層 probe）では不要。Phase C（multi-step loop）で必要。
# public ユーザーは別プロバイダ（OpenAI / Gemini 等）の import + キーに差し替える。
AZURE_OPENAI_API_KEY=
AZURE_RESOURCE_NAME=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
