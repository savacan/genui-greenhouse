# --- Art Institute of Chicago API ---
# 鍵不要・CORS 可。base だけ差し替え可能にしてある。
ART_API_BASE=https://api.artic.edu/api/v1
# 作品画像の IIIF ベース（通常は /search の config.iiif_url と同じ。固定で持つ）。
ART_IIIF_BASE=https://www.artic.edu/iiif/2

# --- LLM プロバイダ（既定 = Azure OpenAI / lib/finder/model.ts で env 差し替え可）---
# public ユーザーは別プロバイダ（OpenAI / Gemini 等）の import + キーに差し替える。
AZURE_OPENAI_API_KEY=
AZURE_RESOURCE_NAME=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
